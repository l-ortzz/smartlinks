// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String         @id @default(cuid())
  name           String
  email          String         @unique
  slug           String         @unique
  numeroWhatsApp String         @unique
  passwordHash   String?
  description    String?
  logo           String?
  heroImage      String?
  instagram      String?
  telefone       String?
  endereco       String?
  subscription   Subscription?
  cpfCnpj        String?
  selectedModule ModuleType?
  products       Product[]
  services       Service[]
  orders         Order[]
  availability   Availability[]
  appointments   Appointment[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([slug])
  @@index([email])
  @@map("users")
}

model Product {
  id           String             @id @default(cuid())
  userId       String
  slug         String
  name         String
  description  String?
  price        Decimal
  images       Json? // Array of image URLs, e.g., ["url1", "url2"]
  stock        Int?
  active       Boolean            @default(true)
  tags         ProductTag[]
  attributes   ProductAttribute[]
  relatedFrom  RelatedProduct[]   @relation("RelatedFrom")
  relatedTo    RelatedProduct[]   @relation("RelatedTo")
  clicks       Click[]
  orderItems   OrderItem[]
  reservations Reservation[]
  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@unique([userId, slug])
  @@index([userId])
  @@index([slug])
  @@index([active])
  @@map("products")
}

model Tag {
  id        String       @id @default(cuid())
  name      String       @unique
  products  ProductTag[]
  createdAt DateTime     @default(now())

  @@index([name])
  @@map("tags")
}

model ProductTag {
  productId  String
  tagId      String
  assignedAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([productId, tagId])
  @@map("product_tags")
}

model ProductAttribute {
  id        String                  @id @default(cuid())
  productId String
  name      String
  values    ProductAttributeValue[]
  product   Product                 @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime                @default(now())
  updatedAt DateTime                @updatedAt

  @@unique([productId, name])
  @@index([productId])
  @@map("product_attributes")
}

model ProductAttributeValue {
  id          String           @id @default(cuid())
  attributeId String
  value       String
  stock       Int?
  attribute   ProductAttribute @relation(fields: [attributeId], references: [id], onDelete: Cascade)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@unique([attributeId, value])
  @@index([attributeId])
  @@map("product_attribute_values")
}

model RelatedProduct {
  productId String
  relatedId String

  product Product @relation("RelatedFrom", fields: [productId], references: [id], onDelete: Cascade)
  related Product @relation("RelatedTo", fields: [relatedId], references: [id], onDelete: Cascade)

  @@id([productId, relatedId])
  @@map("related_products")
}

model Click {
  id        String   @id @default(cuid())
  productId String
  ip        String
  userAgent String?
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([ip])
  @@index([createdAt])
  @@map("clicks")
}

enum OrderStatus {
  PENDING
  PAID
  DELIVERED
  CANCELED
}

model Order {
  id            String      @id @default(cuid())
  userId        String
  customerName  String?
  customerPhone String?
  address       String?
  total         Decimal
  status        OrderStatus @default(PENDING)
  items         OrderItem[]
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([userId])
  @@index([status])
  @@map("orders")
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  quantity  Int     @default(1)
  price     Decimal
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

enum ReservationStatus {
  RESERVED
  CONFIRMED
  CANCELED
  EXPIRED
}

model Reservation {
  id            String            @id @default(cuid())
  productId     String
  customerName  String
  customerPhone String
  quantity      Int               @default(1)
  status        ReservationStatus @default(RESERVED)
  expiresAt     DateTime?
  product       Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([productId])
  @@index([status])
  @@map("reservations")
}

model Service {
  id           String        @id @default(cuid())
  userId       String
  name         String
  description  String?
  duration     Int
  price        Decimal
  image        String?
  active       Boolean       @default(true)
  appointments Appointment[]
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@unique([userId, name])
  @@index([userId])
  @@index([active])
  @@map("services")
}

enum Weekday {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

model Availability {
  id        String   @id @default(cuid())
  userId    String
  weekday   Weekday
  startTime String
  endTime   String
  active    Boolean  @default(true)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, weekday, startTime, endTime])
  @@index([userId])
  @@index([weekday])
  @@index([active])
  @@map("availabilities")
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  COMPLETED
  CANCELED
}

model Appointment {
  id            String            @id @default(cuid())
  userId        String
  serviceId     String
  customerName  String
  customerPhone String
  date          DateTime
  status        AppointmentStatus @default(SCHEDULED)
  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  service       Service           @relation(fields: [serviceId], references: [id])
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([userId])
  @@index([serviceId])
  @@index([date])
  @@index([status])
  @@map("appointments")
}

enum ModuleType {
  PAGES
  AGENDS
}

enum SubscriptionStatus {
  PENDING
  ACTIVE
  CANCELED
  EXPIRED
}

model Plan {
  id            String         @id @default(cuid())
  name          String         @unique
  price         Decimal
  features      Json? // e.g., {"maxProducts": 100, "maxClicks": 10000}
  subscriptions Subscription[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@map("plans")
}

model Subscription {
  id                   String             @id @default(cuid())

  userId               String             @unique
  planId               String

  status SubscriptionStatus @default(PENDING)
  asaasCustomerId      String?
  asaasSubscriptionId  String? @unique

  paymentMethod        String?

  nextDueDate          DateTime?

  startsAt             DateTime           @default(now())
  endsAt               DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan Plan @relation(fields: [planId], references: [id])

  @@index([planId])
  @@index([status])
  @@map("subscriptions")
}
